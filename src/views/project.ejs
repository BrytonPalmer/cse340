<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>

    <p><strong>Description:</strong> <%= project.description %></p>

    <p><strong>Date:</strong> 
        <%= new Date(project.date).toDateString() %>
    </p>

    <p><strong>Location:</strong> <%= project.location %></p>

    <p><strong>Organization:</strong>
        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <p><strong>Categories:</strong>
        <% if (categories.length === 0) { %>
            None
        <% } else { %>
            <% categories.forEach(cat => { %>
                <a href="/category/<%= cat.category_id %>" 
                style="padding:4px 8px; background:#eef; border-radius:4px; margin-right:6px;">
                    <%= cat.name %>
                </a>
            <% }) %>
        <% } %>
    </p>

    <!-- ⭐ VOLUNTEER SECTION ⭐ -->
    <% if (user) { %>
        <% if (!isVolunteering) { %>
            <form action="/projects/<%= project.project_id %>/volunteer" method="POST" style="margin: 20px 0;">
                <button type="submit" class="btn">Volunteer for this Project</button>
            </form>
        <% } else { %>
            <p style="margin: 20px 0; font-weight: bold; color: green;">
                You are volunteering for this project.
            </p>
            <form action="/projects/<%= project.project_id %>/unvolunteer" method="POST" style="margin-bottom: 20px;">
                <button type="submit" class="btn">Remove Me as a Volunteer</button>
            </form>
        <% } %>
    <% } %>
    <!-- ⭐ END VOLUNTEER SECTION ⭐ -->

    <% if (user && user.role_name === 'admin') { %>
        <a href="/edit-project/<%= project.project_id %>" class="btn">Edit Project</a>
        <a href="/project/<%= project.project_id %>/assign-categories" class="btn">Assign Categories</a>
    <% } %>

    <hr>

    <p>
        <a href="/projects">← Back to Upcoming Projects</a>
    </p>
</main>

<%- include('partials/footer') %>