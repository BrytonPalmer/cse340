<%- include('partials/header') %>

<h2><%= organizationDetails.name %></h2>

<% if (organizationDetails.logo_filename) { %>
  <img 
    src="/images/<%= organizationDetails.logo_filename %>" 
    alt="<%= organizationDetails.name %> logo"
    style="max-width: 200px; margin-bottom: 1rem;"
  >
<% } %>

<p><%= organizationDetails.description %></p>

<p><strong>Contact:</strong> <%= organizationDetails.contact_email %></p>

<hr>

<h3>Service Projects</h3>

<% if (projects.length > 0) { %>
  <ul>
    <% projects.forEach(project => { %>
      <li>
        <a href="/project/<%= project.project_id %>">
          <%= project.title %>
        </a>
        — <%= new Date(project.date).toDateString() %>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No service projects found for this organization.</p>
<% } %>

<%- include('partials/footer') %>