<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <strong><%= project.date.toLocaleDateString() %></strong>:
                <%= project.title %>
                (<%= project.organization_name %>)
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>