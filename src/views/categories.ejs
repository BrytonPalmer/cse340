            <a href="/new-category" class="btn">Add New Category</a>
        <% } %>
    </p>

    <ul>
        <% categories.forEach(cat => { %>
            <li>
                <a href="/category/<%= cat.category_id %>">
                    <%= cat.name %>
                </a>
            </li>
        <% }) %>
    </ul>
</main>

