<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Name: <%= name %></p>
    <p>Username: <%= email %></p>

    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/users">View All Users</a></p>
    <% } %>

    <hr>

    <h2>Your Volunteer Projects</h2>

    <% if (volunteerProjects.length === 0) { %>
        <p>You are not volunteering for any projects yet.</p>
    <% } else { %>
        <ul>
            <% volunteerProjects.forEach(project => { %>
                <li style="margin-bottom: 10px;">
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>

                    <form action="/projects/<%= project.project_id %>/unvolunteer" 
                          method="POST" 
                          style="display:inline;">
                        <button type="submit" class="btn">Remove</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    <% } %>
</main>

<%- include('partials/footer') %>